# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
WEBHOOK_SECRET=optional-secret

# OpenAI
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ngrok (get free token at https://dashboard.ngrok.com)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# These are set automatically by docker-compose, override if needed:
# WEBHOOK_URL=         ← auto-detected from ngrok
# DATABASE_PATH=data/finance.db
# HOST=0.0.0.0
# PORT=8000
# LOG_DIR=logs
